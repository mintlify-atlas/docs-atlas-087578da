  "keyFeatures": [
    "Index-first geospatial retrieval with Parquet-cached COG metadata",
    "20x faster cold-start performance vs traditional GDAL/rasterio approaches",
    "Built-in catalog of 12+ datasets (Sentinel-2, Landsat, NAIP, etc.)",
    "Zero data downloads - work with terabytes while storing only megabytes",
    "TorchGeo integration for ML training pipelines",
    "Multi-cloud support (S3, Azure Blob, GCS)",
    "CLI for dataset management and collection building"
  ],
  "publicApiSurface": [
    "rasteret.build() - Build collection from registered dataset",
    "rasteret.build_from_stac() - Build from STAC API",
    "rasteret.build_from_table() - Build from Parquet/GeoParquet",
    "rasteret.load() - Load persisted collection",
    "rasteret.as_collection() - Wrap Arrow table as collection",
    "rasteret.register() - Register custom dataset",
    "rasteret.register_local() - Register local collection",
    "rasteret.create_backend() - Create authenticated I/O backend",
    "Collection.subset() - Filter collection by metadata",
    "Collection.get_numpy() - Get data as NumPy arrays",
    "Collection.get_xarray() - Get data as xarray Dataset",
    "Collection.to_torchgeo_dataset() - Convert to TorchGeo GeoDataset",
    "Collection.export() - Export collection to Parquet",
    "DatasetRegistry.list() - List available datasets",
    "DatasetRegistry.get() - Get dataset descriptor",
    "CLI: rasteret datasets list/info/search",
    "CLI: rasteret collections list/info/build/delete"
  ]
